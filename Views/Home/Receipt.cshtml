<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Order Receipt - Homeground</title>
    <link rel="icon" type="image/x-icon" href="/img/icon.png" />
    <link rel="stylesheet" href="~/css/receipt.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <div class="receipt-wrapper">
        <div class="receipt-container">
            <!-- Header Section -->
            <div class="receipt-header">
                <div class="header-decoration"></div>
                <div class="success-icon">
                    <svg width="50" height="50" viewBox="0 0 50 50" fill="none">
                        <circle cx="25" cy="25" r="24" stroke="white" stroke-width="2"/>
                        <path d="M15 25L22 32L35 19" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
                <h1>Order Successful!</h1>
                <p>Thank you for choosing Homeground</p>
                
                <!-- Logo -->
                <div class="receipt-logo">
                    <img src="/img/logowhite.png" alt="Homeground Logo" />
                </div>
            </div>

            <!-- Points Earned Banner -->
            <div class="points-earned-banner">
                <div class="points-content">
                    <img src="/img/points.png" alt="Points" class="points-icon" />
                    <div class="points-text">
                        <span class="points-label">Points Earned</span>
                        <span class="points-value" id="pointsEarned">0 pts</span>
                    </div>
                </div>
                <div class="points-message">Keep collecting points for exclusive rewards!</div>
            </div>

            <!-- Order Details -->
            <div class="receipt-body">
                <!-- Order Information Grid -->
                <div class="order-info-section">
                    <div class="info-card">
                        <div class="info-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <path d="M9 11H15M9 15H15M21 8.5V16.5C21 17.9 20.1 19 19 19H5C3.9 19 3 17.9 3 16.5V8.5M21 8.5C21 7.1 20.1 6 19 6H5C3.9 6 3 7.1 3 8.5M21 8.5V10C21 11.1 20.1 12 19 12C17.9 12 17 11.1 17 10V8.5M3 8.5V10C3 11.1 3.9 12 5 12C6.1 12 7 11.1 7 10V8.5" stroke="#614c3a" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="info-content">
                            <span class="info-label">Order ID</span>
                            <span class="info-value" id="orderId">Loading...</span>
                        </div>
                    </div>

                    <div class="info-card">
                        <div class="info-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <rect x="3" y="6" width="18" height="15" rx="2" stroke="#614c3a" stroke-width="2"/>
                                <path d="M3 10H21M8 3V6M16 3V6" stroke="#614c3a" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="info-content">
                            <span class="info-label">Date & Time</span>
                            <span class="info-value" id="orderDate">Loading...</span>
                        </div>
                    </div>

                    <div class="info-card">
                        <div class="info-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <circle cx="12" cy="8" r="4" stroke="#614c3a" stroke-width="2"/>
                                <path d="M5 20C5 16.6863 7.68629 14 11 14H13C16.3137 14 19 16.6863 19 20" stroke="#614c3a" stroke-width="2" stroke-linecap="round"/>
                            </svg>
                        </div>
                        <div class="info-content">
                            <span class="info-label">Customer Name</span>
                            <span class="info-value" id="customerName">Loading...</span>
                        </div>
                    </div>

                    <div class="info-card">
                        <div class="info-icon">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                                <rect x="3" y="8" width="18" height="12" rx="2" stroke="#614c3a" stroke-width="2"/>
                                <path d="M7 8V6C7 4.34315 8.34315 3 10 3H14C15.6569 3 17 4.34315 17 6V8" stroke="#614c3a" stroke-width="2"/>
                                <circle cx="12" cy="14" r="2" fill="#614c3a"/>
                            </svg>
                        </div>
                        <div class="info-content">
                            <span class="info-label">Payment Method</span>
                            <span class="payment-method" id="paymentMethod">Loading...</span>
                        </div>
                    </div>
                </div>

                <!-- Order Items Section -->
                <div class="items-section">
                    <h2 class="section-title">
                        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                            <path d="M6 2L3 6V18C3 18.5304 3.21071 19.0391 3.58579 19.4142C3.96086 19.7893 4.46957 20 5 20H15C15.5304 20 16.0391 19.7893 16.4142 19.4142C16.7893 19.0391 17 18.5304 17 18V6L14 2H6Z" stroke="#614c3a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <path d="M3 6H17M13 10C13 11.0609 12.5786 12.0783 11.8284 12.8284C11.0783 13.5786 10.0609 14 9 14C7.93913 14 6.92172 13.5786 6.17157 12.8284C5.42143 12.0783 5 11.0609 5 10" stroke="#614c3a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                        Order Items
                    </h2>
                    <div class="items-container" id="orderItems">
                        <!-- Items will be loaded here -->
                    </div>
                </div>

                <!-- Totals Section -->
                <div class="totals-section">
                    <div class="total-row">
                        <span>Subtotal</span>
                        <span id="subtotal">₱0.00</span>
                    </div>
                    <div class="total-row">
                        <span>Delivery Fee</span>
                        <span id="deliveryFee">₱50.00</span>
                    </div>
                    <div class="total-divider"></div>
                    <div class="total-row grand-total">
                        <span>Total Amount</span>
                        <span id="grandTotal">₱0.00</span>
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="receipt-actions">
                    <a href="/Home/Menu" class="btn btn-primary">
                            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                                <path d="M3 3H7L9 13H16L18 6H8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <circle cx="9" cy="17" r="1" fill="currentColor"/>
                                <circle cx="16" cy="17" r="1" fill="currentColor"/>
                            </svg>
                            Continue Shopping
                        </a>

                        <a href="/Home/OrderHistory" class="btn btn-track">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                                <path d="M9 11l3 3L22 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Track Order
                        </a>
        </div>
    </div>

@if (TempData["ConfirmedOrderId"] != null)
{
    <script>
        localStorage.setItem('lastOrderId', '@TempData["ConfirmedOrderId"]');
    </script>
}

<script>
document.addEventListener('DOMContentLoaded', async function () {
    const orderId = localStorage.getItem('lastOrderId');

    if (!orderId) {
        window.location.href = '/Home/Menu';
        return;
    }

    const res  = await fetch(`/Home/GetOrder?orderId=${orderId}`);
    const data = await res.json();

    if (!data.success) {
        window.location.href = '/Home/Menu';
        return;
    }

    document.getElementById('orderId').textContent       = data.orderId;
    document.getElementById('orderDate').textContent     = data.createdAt;
    document.getElementById('customerName').textContent  = data.fullName;
    document.getElementById('paymentMethod').textContent = data.paymentMethod.toUpperCase();
    document.getElementById('pointsEarned').textContent  = data.pointsEarned + ' pts';
    document.getElementById('subtotal').textContent      = '₱' + data.subtotal.toFixed(2);
    document.getElementById('deliveryFee').textContent   = '₱' + data.deliveryFee.toFixed(2);
    document.getElementById('grandTotal').textContent    = '₱' + data.total.toFixed(2);

    const container = document.getElementById('orderItems');
    container.innerHTML = data.items.map(item => `
        <div class="order-item">
            <div class="item-image-wrapper">
                <img src="${item.image}" class="item-image" alt="${item.productName}">
            </div>
            <div class="item-details">
                <div class="item-info">
                    <h3>${item.productName}</h3>
                    <div class="item-meta">
                        <span class="item-quantity">Qty: ${item.quantity}</span>
                        <span class="item-unit-price">₱${item.price.toFixed(2)} each</span>
                    </div>
                </div>
                <span class="item-price">₱${(item.price * item.quantity).toFixed(2)}</span>
            </div>
        </div>
    `).join('');

    localStorage.removeItem('lastOrderId');
});
</script>

</body>
</html>